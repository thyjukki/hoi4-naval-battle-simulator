{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spirits.schema.json",
  "title": "NavySimulator Spirits",
  "type": "object",
  "required": ["spirits"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "spirits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/spiritId" },
          "statModifiers": { "$ref": "common.schema.json#/$defs/shipStats" },
          "statMultiplier": { "$ref": "common.schema.json#/$defs/shipStats" },
          "statMultipliers": { "$ref": "common.schema.json#/$defs/shipStats" },
          "statAverages": { "$ref": "common.schema.json#/$defs/shipStats" },
          "appliesToRoles": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/shipRole" },
            "uniqueItems": true
          },
          "appliesToTypes": {
            "type": "array",
            "items": { "$ref": "#/$defs/shipType" },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "shipType": {
      "type": "string",
      "enum": [
        "SHBB",
        "Battleship",
        "Battlecruiser",
        "Carrier",
        "Heavy Cruiser",
        "Light Cruiser",
        "Torpedo Cruiser",
        "Destroyer",
        "Submarine"
      ]
    }
  },
  "additionalProperties": false
}

