{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "planes.schema.json",
  "title": "NavySimulator Planes",
  "type": "object",
  "required": ["planes"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "planes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "stats"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/id" },
          "stats": {
            "type": "object",
            "required": [
              "airDefense",
              "airAttack",
              "navalAttack",
              "speed",
              "agility",
              "airSuperiority",
              "navalTargeting",
              "reliability",
              "productionCost"
            ],
            "properties": {
              "airDefense": { "type": "number" },
              "airAttack": { "type": "number" },
              "navalAttack": { "type": "number" },
              "speed": { "type": "number" },
              "agility": { "type": "number" },
              "airSuperiority": { "type": "number" },
              "navalTargeting": { "type": "number" },
              "reliability": { "type": "number" },
              "productionCost": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

