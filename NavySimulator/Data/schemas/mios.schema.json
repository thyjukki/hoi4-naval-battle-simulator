{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mios.schema.json",
  "title": "NavySimulator MIOs",
  "type": "object",
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "shipRole": {
      "type": "string",
      "enum": ["Screen", "Capital", "Carrier", "Submarine", "Convoy"]
    },
    "shipType": {
      "type": "string",
      "enum": [
        "SHBB",
        "Battleship",
        "Battlecruiser",
        "Carrier",
        "Heavy Cruiser",
        "Light Cruiser",
        "Torpedo Cruiser",
        "Destroyer",
        "Submarine"
      ]
    },
    "shipStats": {
      "type": "object",
      "properties": {
        "speed": { "type": "number" },
        "reliability": { "type": "number" },
        "organization": { "type": "number" },
        "hp": { "type": "number" },
        "surfaceVisibility": { "type": "number" },
        "subVisibility": { "type": "number" },
        "surfaceDetection": { "type": "number" },
        "subDetection": { "type": "number" },
        "carrierSubDetection": { "type": "number" },
        "carrierSurfaceDetection": { "type": "number" },
        "carrierSize": { "type": "number" },
        "lightAttack": { "type": "number" },
        "lightPiercing": { "type": "number" },
        "heavyAttack": { "type": "number" },
        "heavyPiercing": { "type": "number" },
        "torpedoAttack": { "type": "number" },
        "depthChargeAttack": { "type": "number" },
        "antiAir": { "type": "number" },
        "armor": { "type": "number" },
        "torpedoDamageReductionFactor": { "type": "number" },
        "torpedoEnemyCriticalChanceFactor": { "type": "number" },
        "torpedoHitChanceFactor": { "type": "number" },
        "lightHitChangeFactor": { "type": "number" },
        "lightHitChanceFactor": { "type": "number" },
        "heavyHitChangeFactor": { "type": "number" },
        "navalWeatherPenaltyFactor": { "type": "number" },
        "productionCost": { "type": "number" }
      },
      "additionalProperties": false
    }
  },
  "required": ["mios"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "mios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "modifiers"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/mioId" },
          "modifiers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "statModifiers": { "$ref": "#/$defs/shipStats" },
                "statMultiplier": { "$ref": "#/$defs/shipStats" },
                "statMultipliers": { "$ref": "#/$defs/shipStats" },
                "statAverages": { "$ref": "#/$defs/shipStats" },
                "appliesToRoles": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/shipRole" },
                  "uniqueItems": true
                },
                "appliesToTypes": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/shipType" },
                  "uniqueItems": true
                }
              },
              "additionalProperties": false,
              "anyOf": [
                { "required": ["statModifiers"] },
                { "required": ["statMultiplier"] },
                { "required": ["statMultipliers"] },
                { "required": ["statAverages"] }
              ]
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

