{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "force-compositions.schema.json",
  "title": "NavySimulator Force Compositions",
  "type": "object",
  "required": ["fleets"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "fleets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "shipDesigns"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/id" },
          "shipDesigns": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "integer",
              "minimum": 1
            }
          },
          "shipExperienceLevels": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0,
              "maximum": 7
            }
          },
          "carrierAirwings": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["planeID", "type", "airwings"],
                "properties": {
                  "planeID": { "$ref": "common.schema.json#/$defs/id" },
                  "type": {
                    "type": "string",
                    "enum": ["fighter", "figheter", "bomber"]
                  },
                  "airwings": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "planeCount": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

