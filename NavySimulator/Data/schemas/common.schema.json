{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common.schema.json",
  "title": "NavySimulator Common Definitions",
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "mioId": {
      "type": "string",
      "enum": [
        "battle_line_armor_armor_ha",
        "battle_line_armor_armor_la"
      ]
    },
    "researchId": {
      "type": "string",
      "enum": [
        "damage_control_1",
        "damage_control_2",
        "fire_control_methods_1",
        "fire_control_methods_2",
        "fire_control_methods_3",
        "heavy_upgrade_1",
        "heavy_upgrade_2",
        "light_upgrade_1",
        "light_upgrade_2",
        "smoke_generators",
        "torpedo_upgrade_1",
        "torpedo_upgrade_2"
      ]
    },
    "spiritId": {
      "type": "string",
      "enum": [
        "brave_commanders",
        "close_combat",
        "decisive_battle",
        "efficient_communications",
        "fleet_defense",
        "inclement_weather",
        "naval_tripwire",
        "night_fighting"
      ]
    },
    "shipRole": {
      "type": "string",
      "enum": ["Screen", "Capital", "Carrier", "Submarine", "Convoy"]
    },
    "shipStats": {
      "type": "object",
      "description": "Numeric stat map. Allows known stats and other numeric keys for imported/experimental values.",
      "properties": {
        "speed": { "type": "number" },
        "reliability": { "type": "number" },
        "organization": { "type": "number" },
        "hp": { "type": "number" },
        "surfaceVisibility": { "type": "number" },
        "subVisibility": { "type": "number" },
        "surfaceDetection": { "type": "number" },
        "subDetection": { "type": "number" },
        "carrierSubDetection": { "type": "number" },
        "carrierSurfaceDetection": { "type": "number" },
        "carrierSize": { "type": "number" },
        "lightAttack": { "type": "number" },
        "lightPiercing": { "type": "number" },
        "heavyAttack": { "type": "number" },
        "heavyPiercing": { "type": "number" },
        "torpedoAttack": { "type": "number" },
        "depthChargeAttack": { "type": "number" },
        "antiAir": { "type": "number" },
        "armor": { "type": "number" },
        "torpedoDamageReductionFactor": { "type": "number" },
        "torpedoEnemyCriticalChanceFactor": { "type": "number" },
        "torpedoHitChanceFactor": { "type": "number" },
        "lightHitChangeFactor": { "type": "number" },
        "lightHitChanceFactor": { "type": "number" },
        "heavyHitChangeFactor": { "type": "number" },
        "navalWeatherPenaltyFactor": { "type": "number" },
        "productionCost": { "type": "number" }
      },
      "additionalProperties": false
    }
  }
}

